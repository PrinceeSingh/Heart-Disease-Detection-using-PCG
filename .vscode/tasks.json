{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run All Tests",
      "type": "shell",
      "command": "pytest",
      "args": ["tests/", "-v"],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Run Model Tests",
      "type": "shell",
      "command": "pytest",
      "args": ["tests/test_model.py", "-v"]
    },
    {
      "label": "Run with Coverage",
      "type": "shell",
      "command": "pytest",
      "args": ["tests/", "--cov=src", "--cov-report=html"]
    }
  ]
}